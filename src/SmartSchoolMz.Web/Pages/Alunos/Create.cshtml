@page
@model SmartSchoolMz.Web.Pages.Alunos.CreateModel
@{
    ViewData["Title"] = "Novo Aluno";
}

<h1>Cadastrar Novo Aluno</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form method="post">
            <div class="mb-3">
                <label for="Input_NomeCompleto" class="form-label">Nome Completo</label>
                <input id="Input_NomeCompleto" name="Input.NomeCompleto" class="form-control" value="@Model.Input.NomeCompleto" />
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label for="Input_DataNascimento" class="form-label">Data de Nascimento</label>
                    <input id="Input_DataNascimento" name="Input.DataNascimento" type="date" class="form-control" value="@Model.Input.DataNascimento.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col">
                    <label for="Input_Sexo" class="form-label">Sexo</label>
                    <select id="Input_Sexo" name="Input.Sexo" class="form-select">
                        @foreach (var value in Enum.GetValues(typeof(SmartSchoolMz.Domain.Enums.Sexo)))
                        {
                            <option value="@((int)value)" selected="@(Model.Input.Sexo == (SmartSchoolMz.Domain.Enums.Sexo)value)">@value</option>
                        }
                    </select>
                </div>
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label for="Input_DocumentoIdentificacao" class="form-label">Documento ID</label>
                    <input id="Input_DocumentoIdentificacao" name="Input.DocumentoIdentificacao" class="form-control" value="@Model.Input.DocumentoIdentificacao" />
                </div>
                <div class="col">
                    <label for="Input_NumeroMatricula" class="form-label">Nº Matrícula</label>
                    <input id="Input_NumeroMatricula" name="Input.NumeroMatricula" class="form-control" value="@Model.Input.NumeroMatricula" />
                </div>
            </div>
            <div class="mb-3">
                <label for="Input_Morada" class="form-label">Morada</label>
                <input id="Input_Morada" name="Input.Morada" class="form-control" value="@Model.Input.Morada" />
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label for="Input_Contacto" class="form-label">Contacto</label>
                    <input id="Input_Contacto" name="Input.Contacto" class="form-control" value="@Model.Input.Contacto" />
                </div>
                <div class="col">
                    <label for="Input_Email" class="form-label">Email</label>
                    <input id="Input_Email" name="Input.Email" type="email" class="form-control" value="@Model.Input.Email" />
                </div>
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Salvar</button>
                <a asp-page="./Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>


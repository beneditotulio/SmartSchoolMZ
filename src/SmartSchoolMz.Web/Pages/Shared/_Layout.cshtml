<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartSchoolMz</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartSchoolMz.Web.styles.css" asp-append-version="true" />
    <style>
        :root {
            --primary-color: #4361ee;
            --secondary-color: #3f37c9;
            --success-color: #06d6a0;
            --warning-color: #ffd166;
            --danger-color: #ef476f;
            --dark-color: #1d3557;
            --light-color: #f8f9fa;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
            min-height: 100vh;
        }
        
        .navbar {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            box-shadow: 0 4px 20px rgba(67, 97, 238, 0.3);
        }
        
        .navbar-brand {
            font-weight: 700;
            font-size: 1.5rem;
            color: white !important;
        }
        
        .nav-link {
            color: rgba(255, 255, 255, 0.9) !important;
            font-weight: 500;
            margin: 0 8px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        .nav-link:hover, .nav-link.active {
            background: rgba(255, 255, 255, 0.2);
            color: white !important;
        }
        
        .dashboard-card {
            border: none;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            margin-bottom: 24px;
        }
        
        .dashboard-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
        }
        
        .card-header {
            padding: 24px;
            border: none;
        }
        
        .card-icon {
            width: 64px;
            height: 64px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin-bottom: 16px;
            background: rgba(255, 255, 255, 0.2);
        }
        
        .card-body {
            padding: 24px;
            background: white;
        }
        
        .card-title {
            font-weight: 700;
            font-size: 1.25rem;
            margin-bottom: 8px;
        }
        
        .card-text {
            color: #6c757d;
            margin-bottom: 20px;
        }
        
        .btn-primary-custom {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            border: none;
            border-radius: 12px;
            padding: 12px 28px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(67, 97, 238, 0.4);
        }
        
        .page-header {
            margin: 40px 0;
            padding: 32px;
            background: linear-gradient(135deg, white 0%, #f8f9fa 100%);
            border-radius: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        }
        
        .page-title {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--dark-color);
            margin-bottom: 8px;
        }
        
        .page-subtitle {
            font-size: 1.1rem;
            color: #6c757d;
        }
        
        .footer {
            background: var(--dark-color);
            color: rgba(255, 255, 255, 0.8);
            margin-top: 60px;
            padding: 32px 0;
        }
    </style>
</head>
<body>
    @{
        var role = Context.Session.GetString("UserRole") ?? "Admin";
    }
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="@(role == "Admin" ? "/Dashboard" : "/Login")">
                    <i class="fas fa-graduation-cap me-2"></i>
                    SmartSchoolMz
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-lg-4">
                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Dashboard">
                                    <i class="fas fa-home me-1"></i>
                                    Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Alunos/Index">
                                    <i class="fas fa-users me-1"></i>
                                    Alunos
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Turmas/Index">
                                    <i class="fas fa-door-open me-1"></i>
                                    Turmas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Matriculas/Index">
                                    <i class="fas fa-clipboard-list me-1"></i>
                                    Matrículas
                                </a>
                            </li>
                        }
                        else if (role == "Professor")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Dashboard">
                                    <i class="fas fa-home me-1"></i>
                                    Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-door-open me-1"></i>
                                    Minhas Turmas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-star me-1"></i>
                                    Lançar Notas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-calendar-check me-1"></i>
                                    Frequência
                                </a>
                            </li>
                        }
                        else if (role == "Encarregado")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Dashboard">
                                    <i class="fas fa-home me-1"></i>
                                    Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-star me-1"></i>
                                    Notas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-calendar-check me-1"></i>
                                    Frequência
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-credit-card me-1"></i>
                                    Pagamentos
                                </a>
                            </li>
                        }
                        else if (role == "Aluno")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-page="/Dashboard">
                                    <i class="fas fa-home me-1"></i>
                                    Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-star me-1"></i>
                                    Minhas Notas
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-calendar-check me-1"></i>
                                    Minha Frequência
                                </a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-page="/Login">
                                <i class="fas fa-sign-out-alt me-1"></i>
                                @(role == "Admin" ? "Sair" : "Mudar Perfil")
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container text-center">
            <p class="mb-0">
                &copy; 2026 - SmartSchoolMz - Sistema Integrado de Gestão Escolar
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


@page
@model LoginModel
@{
    ViewData["Title"] = "Login - SmartSchoolMz";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card" style="border: none; border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.1); overflow: hidden;">
                <div class="card-body p-5">
                    <div class="text-center mb-5">
                    <div class="mb-4">
                        <i class="fas fa-graduation-cap" style="font-size: 4rem; color: var(--primary-color);"></i>
                    </div>
                    <h2 style="font-weight: 800; color: var(--dark-color);">SmartSchoolMz</h2>
                    <p class="text-muted">Sistema Integrado de Gestão Escolar</p>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <div>
                            @Model.ErrorMessage
                        </div>
                    </div>
                }

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600;">Nome de Utilizador</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background: #f8f9fa; border-right: none;">
                                <i class="fas fa-user" style="color: var(--primary-color);"></i>
                            </span>
                            <input type="text" class="form-control" asp-for="Username" placeholder="Introduza o seu nome de utilizador" style="border-left: none;">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600;">Senha</label>
                        <div class="input-group">
                            <span class="input-group-text" style="background: #f8f9fa; border-right: none;">
                                <i class="fas fa-lock" style="color: var(--primary-color);"></i>
                            </span>
                            <input type="password" class="form-control" asp-for="Password" placeholder="Introduza a sua senha" style="border-left: none;">
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3" style="font-size: 1.1rem; font-weight: 700;">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Entrar
                    </button>
                </form>

                <div class="text-center mt-4">
                    <div class="mb-3">
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Credenciais de teste:
                        </small>
                    </div>
                    <div class="row g-2 text-start">
                        <div class="col-6">
                            <small class="text-muted"><strong>Admin:</strong> admin / admin123</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted"><strong>Professor:</strong> professor / professor123</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted"><strong>Encarregado:</strong> encarregado / encarregado123</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted"><strong>Aluno:</strong> aluno / aluno123</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


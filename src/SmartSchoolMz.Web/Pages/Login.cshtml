@page
@model LoginModel
@{
    ViewData["Title"] = "Login - SmartSchoolMz";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card" style="border: none; border-radius: 24px; box-shadow: 0 20px 60px rgba(0,0,0,0.1); overflow: hidden;">
                <div class="card-body p-5">
                    <div class="text-center mb-5">
                    <div class="mb-4">
                        <i class="fas fa-graduation-cap" style="font-size: 4rem; color: var(--primary-color);"></i>
                    </div>
                    <h2 style="font-weight: 800; color: var(--dark-color);">SmartSchoolMz</h2>
                    <p class="text-muted">Sistema Integrado de Gestão Escolar</p>
                </div>

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600;">Selecione o seu perfil</label>
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="form-check p-3 border rounded-3" style="cursor: pointer; transition: all 0.3s ease;">
                                    <input class="form-check-input" type="radio" name="Role" id="roleAdmin" value="Admin" checked>
                                    <label class="form-check-label w-100" for="roleAdmin">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #4361ee, #3a0ca3); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-user-shield text-white"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0" style="font-weight: 700;">Administrador</h6>
                                                <small class="text-muted">Gestão total do sistema</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check p-3 border rounded-3" style="cursor: pointer; transition: all 0.3s ease;">
                                    <input class="form-check-input" type="radio" name="Role" id="roleProfessor" value="Professor">
                                    <label class="form-check-label w-100" for="roleProfessor">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #06d6a0, #05a77d); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-chalkboard-teacher text-white"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0" style="font-weight: 700;">Professor</h6>
                                                <small class="text-muted">Lançamento de notas e frequência</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check p-3 border rounded-3" style="cursor: pointer; transition: all 0.3s ease;">
                                    <input class="form-check-input" type="radio" name="Role" id="roleEncarregado" value="Encarregado">
                                    <label class="form-check-label w-100" for="roleEncarregado">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #ffd166, #fca311); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-user-tie text-white"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0" style="font-weight: 700;">Encarregado de Educação</h6>
                                                <small class="text-muted">Consulta do desempenho e pagamentos</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="form-check p-3 border rounded-3" style="cursor: pointer; transition: all 0.3s ease;">
                                    <input class="form-check-input" type="radio" name="Role" id="roleAluno" value="Aluno">
                                    <label class="form-check-label w-100" for="roleAluno">
                                        <div class="d-flex align-items-center">
                                            <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #ef476f, #d00000); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                                                <i class="fas fa-user-graduate text-white"></i>
                                            </div>
                                            <div>
                                                <h6 class="mb-0" style="font-weight: 700;">Aluno</h6>
                                                <small class="text-muted">Consulta de notas e frequência</small>
                                            </div>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary-custom w-100 py-3" style="font-size: 1.1rem; font-weight: 700;">
                        <i class="fas fa-sign-in-alt me-2"></i>
                        Entrar
                    </button>
                </form>

                <div class="text-center mt-4">
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Este é um protótipo - os dados são simulados
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>


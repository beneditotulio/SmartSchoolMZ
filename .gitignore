## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][In][32]/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use Visual Studio Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build tool reports
*.trx
*.xml

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# MonoAutoTest
mono_crash.*

# BlueJ files
*.ctxt

# GPState files
gppg.state
gplex.state

# Entity Framework worker file
*.es5.js
*.es5.js.map

# MSBuild Binary and Structured Log files
*.binlog

# Visual Studio cache files
# This folder contains specific settings for a user; setup files for VS2017
.mfractor/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.bak

# Microsoft Azure Build Output
csx/
*.kdmerge
*.cscfg
*.csdef
*.pubxml
*.publishsettings

# Rider
.idea/
*.sln.iml

# Mac
.DS_Store

# Web
node_modules/
.npm/
.yarn/
dist/
wwwroot/lib/

# OS
Thumbs.db
ehthumbs.db
Desktop.ini

# User appsettings
appsettings.Development.json
appsettings.Local.json

# Data Protection Keys
Keys/
